cmake_minimum_required(VERSION 3.18...3.27)
project("pysf" LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_POSITION_INDEPENDENT_CODE ON)

set(CMAKE_OSX_DEPLOYMENT_TARGET "12.0" CACHE STRING "Minimum macOS version to build for")

find_package(Python3 {python_version} EXACT REQUIRED COMPONENTS Interpreter Development.Module)

if(NOT Python3_FOUND)
    message(FATAL_ERROR "Python {python_version} not found with development modules.")
endif()

execute_process(
    COMMAND "${{Python3_EXECUTABLE}}" -m pybind11 --cmakedir
    OUTPUT_VARIABLE PYBIND11_CMAKE_DIR
    OUTPUT_STRIP_TRAILING_WHITESPACE
    RESULT_VARIABLE PYBIND11_RESULT
    ERROR_QUIET
)

if(NOT PYBIND11_RESULT EQUAL 0 OR NOT EXISTS "${{PYBIND11_CMAKE_DIR}}")
    execute_process(
        COMMAND "${{Python3_EXECUTABLE}}" -c "import pybind11; print(pybind11.get_cmake_dir())"
        OUTPUT_VARIABLE PYBIND11_CMAKE_DIR
        OUTPUT_STRIP_TRAILING_WHITESPACE
        RESULT_VARIABLE PYBIND11_RESULT
    )
endif()

if(NOT PYBIND11_RESULT EQUAL 0)
    message(FATAL_ERROR 
        "Could not find pybind11 cmake config.\n"
        "Please ensure pybind11 is installed in the current environment:\n"
        "   ${{Python3_EXECUTABLE}} -m pip install pybind11\n"
        "Current Python: ${{Python3_EXECUTABLE}}\n"
        "Error Code: ${{PYBIND11_RESULT}}"
    )
endif()

message(STATUS "Found pybind11 cmake dir: ${{PYBIND11_CMAKE_DIR}}")

find_package(pybind11 CONFIG REQUIRED PATHS "${{PYBIND11_CMAKE_DIR}}" NO_DEFAULT_PATH)

set(SFML_DIR ${{CMAKE_SOURCE_DIR}}/SFML)
set(BUILD_SHARED_LIBS ON CACHE BOOL "Build shared SFML libs" FORCE)
add_subdirectory(${{SFML_DIR}})

if(WIN32)
    set(TARGET_SUFFIX ".pyd")
elseif(APPLE)
    set(TARGET_SUFFIX ".so")
    set(CMAKE_MACOSX_RPATH TRUE)
else()
    set(TARGET_SUFFIX ".so")
endif()

include_directories(${{CMAKE_SOURCE_DIR}}/include)
include_directories(${{CMAKE_SOURCE_DIR}}/output/include)

set(PYSF_SOURCES
{sources}
    "output/main.cpp"
)

if(APPLE)
    list(APPEND PYSF_SOURCES 
{mm_sources}
    )
endif()

add_library(pysf MODULE ${{PYSF_SOURCES}})

target_link_libraries(pysf PRIVATE
    pybind11::module 
    Python3::Module
    sfml-system
    sfml-window
    sfml-graphics
    sfml-audio
    sfml-network
)

set_target_properties(pysf PROPERTIES
    PREFIX ""
    SUFFIX ${{TARGET_SUFFIX}}
    LIBRARY_OUTPUT_DIRECTORY ${{CMAKE_BINARY_DIR}}/bin
)

if(APPLE)
    set_target_properties(pysf PROPERTIES
        BUILD_WITH_INSTALL_RPATH TRUE
        INSTALL_RPATH "@loader_path"
        MACOSX_RPATH TRUE
    )
endif()

if(NOT CMAKE_CONFIGURATION_TYPES)
    if(NOT CMAKE_BUILD_TYPE)
        set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type" FORCE)
    endif()
endif()

if(MSVC)
    target_compile_options(pysf PRIVATE /O2 /DNDEBUG)
else()
    target_compile_options(pysf PRIVATE -O3 -DNDEBUG)
    set_target_properties(pysf PROPERTIES INTERPROCEDURAL_OPTIMIZATION TRUE)
endif()

if(NOT MSVC AND CMAKE_BUILD_TYPE STREQUAL "Release")
    if(APPLE)
        add_custom_command(TARGET pysf POST_BUILD
            COMMAND strip -x $<TARGET_FILE:pysf>
        )
    endif()
endif()
